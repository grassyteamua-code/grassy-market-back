generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SELLER
  BUYER_NATURAL_PERSON
  BUYER_JURIDICAL_PERSON
  CARRIER
}

model Seller {
  id              String          @id @default(uuid())
  email           String
  firstName       String
  middleName      String
  lastName        String
  password        String
  companyName     String
  contactPerson   String
  phone           String
  companyAddress  String
  edrpou          String          @unique
  verificationDoc String
  acceptTerms     Boolean         @default(false)
  refreshTokens   RefreshToken[]
  userSocials     UserSocial[]
  auditLogs       AuditLog[]
  resetPasswords  ResetPassword[]
  carts           Cart[]
  orders          Order[]
  payments        Payment[]
}

model BuyerJuridicalPerson {
  id              String          @id @default(uuid())
  email           String
  firstName       String
  middleName      String
  lastName        String
  password        String
  companyName     String
  contactPerson   String
  phone           String
  companyAddress  String
  edrpou          String          @unique
  verificationDoc String
  acceptTerms     Boolean         @default(false)
  refreshTokens   RefreshToken[]
  userSocials     UserSocial[]
  auditLogs       AuditLog[]
  resetPasswords  ResetPassword[]
  carts           Cart[]
  orders          Order[]
  payments        Payment[]
}

model BuyerNaturalPerson {
  id              String          @id @default(uuid())
  email           String
  password        String
  firstName       String
  middleName      String
  lastName        String
  phone           String
  address         String
  acceptTerms     Boolean         @default(false)
  refreshTokens   RefreshToken[]
  userSocials     UserSocial[]
  auditLogs       AuditLog[]
  resetPasswords  ResetPassword[]
  carts           Cart[]
  orders          Order[]
  payments        Payment[]
}

model Carrier {
  id              String          @id @default(uuid())
  email           String
  password        String
  firstName       String
  middleName      String
  lastName        String
  companyName     String
  edrpou          String          @unique
  phone           String
  vehicleDetails  String
  location        String
  acceptTerms     Boolean         @default(false)
  refreshTokens   RefreshToken[]
  userSocials     UserSocial[]
  auditLogs       AuditLog[]
  resetPasswords  ResetPassword[]
  carts           Cart[]
  orders          Order[]
  payments        Payment[]
}

model RefreshToken {
  id                     String               @id @default(uuid())
  createdAt              DateTime             @default(now())
  expiresAt              DateTime
  token                  String
  sellerId               String
  seller                 Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyerJuridicalPersonId String
  buyerJuridicalPerson   BuyerJuridicalPerson @relation(fields: [buyerJuridicalPersonId], references: [id], onDelete: Cascade)
  buyerNaturalPersonId   String
  buyerNaturalPerson     BuyerNaturalPerson   @relation(fields: [buyerNaturalPersonId], references: [id], onDelete: Cascade)
  carrierId              String
  carrier                Carrier              @relation(fields: [carrierId], references: [id], onDelete: Cascade)
}

model UserSocial {
  id                     String               @id @default(uuid())
  accessToken            String
  createdAt              DateTime             @default(now())
  email                  String
  isLinked               Int
  provider               String
  refreshToken           String
  tokenExpiresAt         DateTime                     
  updatedAt              DateTime             @updatedAt
  sellerId               String
  seller                 Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyerJuridicalPersonId String
  buyerJuridicalPerson   BuyerJuridicalPerson @relation(fields: [buyerJuridicalPersonId], references: [id], onDelete: Cascade)
  buyerNaturalPersonId   String
  buyerNaturalPerson     BuyerNaturalPerson   @relation(fields: [buyerNaturalPersonId], references: [id], onDelete: Cascade)
  carrierId              String
  carrier                Carrier              @relation(fields: [carrierId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id                     String               @id @default(uuid())
  action                 String
  createdAt              DateTime             @default(now())
  ipAddress              String
  userAgent              String
  sellerId               String
  seller                 Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyerJuridicalPersonId String
  buyerJuridicalPerson   BuyerJuridicalPerson @relation(fields: [buyerJuridicalPersonId], references: [id], onDelete: Cascade)
  buyerNaturalPersonId   String
  buyerNaturalPerson     BuyerNaturalPerson   @relation(fields: [buyerNaturalPersonId], references: [id], onDelete: Cascade)
  carrierId              String
  carrier                Carrier              @relation(fields: [carrierId], references: [id], onDelete: Cascade)
}

model ResetPassword {
  id                     String               @id @default(uuid())
  createdAt              DateTime             @default(now())
  expiresAt              DateTime
  tokenHash              String
  sellerId               String
  seller                 Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyerJuridicalPersonId String
  buyerJuridicalPerson   BuyerJuridicalPerson @relation(fields: [buyerJuridicalPersonId], references: [id], onDelete: Cascade)
  buyerNaturalPersonId   String
  buyerNaturalPerson     BuyerNaturalPerson   @relation(fields: [buyerNaturalPersonId], references: [id], onDelete: Cascade)
  carrierId              String
  carrier                Carrier              @relation(fields: [carrierId], references: [id], onDelete: Cascade)
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Decimal
  stock       Int
  sku         String      @unique
  isActive    Boolean     @default(true)
  imageUrl    String?
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  status      String?
  slug        String    @unique
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Order {
  id                     String               @id @default(uuid())
  orderNumber            String               @unique
  status                 String
  totalAmount            Decimal
  shippingAddress        String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  orderItems             OrderItem[]
  payments               Payment[]
  sellerId               String
  seller                 Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyerJuridicalPersonId String
  buyerJuridicalPerson   BuyerJuridicalPerson @relation(fields: [buyerJuridicalPersonId], references: [id], onDelete: Cascade)
  buyerNaturalPersonId   String
  buyerNaturalPerson     BuyerNaturalPerson   @relation(fields: [buyerNaturalPersonId], references: [id], onDelete: Cascade)
  carrierId              String
  carrier                Carrier              @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  cartId                 String
  cart                   Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model Cart {
  id                     String               @id @default(uuid())
  checkedOut             Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  cartItems              CartItem[]
  orders                 Order[]
  sellerId               String
  seller                 Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyerJuridicalPersonId String
  buyerJuridicalPerson   BuyerJuridicalPerson @relation(fields: [buyerJuridicalPersonId], references: [id], onDelete: Cascade)
  buyerNaturalPersonId   String
  buyerNaturalPerson     BuyerNaturalPerson   @relation(fields: [buyerNaturalPersonId], references: [id], onDelete: Cascade)
  carrierId              String
  carrier                Carrier              @relation(fields: [carrierId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        String   @id @default(uuid())
  quantity  Int
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  quantity  Int
  price     Decimal
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id                     String               @id @default(uuid())
  amount                 Decimal
  status                 String
  currency               String               @default("UAH")
  paymentMethod          String
  transactionId          String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  orderId                String
  order                  Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerId               String
  seller                 Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyerJuridicalPersonId String
  buyerJuridicalPerson   BuyerJuridicalPerson @relation(fields: [buyerJuridicalPersonId], references: [id], onDelete: Cascade)
  buyerNaturalPersonId   String
  buyerNaturalPerson     BuyerNaturalPerson   @relation(fields: [buyerNaturalPersonId], references: [id], onDelete: Cascade)
  carrierId              String
  carrier                Carrier              @relation(fields: [carrierId], references: [id], onDelete: Cascade)
}
