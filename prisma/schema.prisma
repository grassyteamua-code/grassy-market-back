generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SELLER
  BUYER
  CARRIER
}

model User {
  id                String            @id @default(uuid())
  username          String            @unique
  email             String            @unique
  password          String
  passwordRepeat    String            @map("password_repeat")
  firstName         String            @map("first_name")
  middleName        String            @map("middle_name")
  lastName          String            @map("last_name")
  mobilephone       String
  role              Role[]            @default([SELLER])
  status            String
  buyerProfile      BayerProfile?
  carrierProfile    CarrierProfile?
  sellerProfile     SellerProfile?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  refreshTokens     RefreshToken[]
  userSocials       UserSocial[]
  auditLogs         AuditLog[]
  resetPasswords    ResetPassword[]
  carts             Cart[]
  orders            Order[]
  payments          Payment[]
  leaseDetails      LeaseDetails[]
  tokens            Token[]

  @@map("users")
  transactions Transaction[]
}

model SellerProfile {
  id                  String     @id @default(uuid())
  companyName         String     @map("company_name ")
  contactPerson       String     @map("contact_person")
  phone               String  
  companyAddress      String     @map("company_address")
  edrpou              String     @unique
  verificationDoc     String     @map("verification_doc")
  certificationDoc    String?    @map("certification_doc")
  acceptTerms         Boolean    @default(false)
  userId              String     @unique
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sellers_profiles")
}

model BayerProfile {
  id                  String     @id @default(uuid())
  companyName         String     @map("company_name")
  contactPerson       String     @map("contact_person")
  phone               String
  companyAddress      String     @map("company_address")
  edrpou              String     @unique
  verificationDoc     String     @map("verification_doc")
  certificationDoc    String?    @map("certification_doc")
  acceptTerms         Boolean    @default(false)
  userId              String     @unique
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("buyers_profiles")
}

model CarrierProfile {
  id                   String      @id @default(uuid())
  companyName          String      @map("company_name")
  contactPerson        String      @map("contact_person")
  phone                String
  edrpou               String      @unique 
  vehicleDetails       String      @map("vehicle_details")
  vehicleType          String      @map("vehicle_type")
  capacity             String      
  locations            String      
  driverLicense        String      @map("driver_license")
  technicalPassport    String      @map("technical_passport")
  isLeased             Boolean?    @map("is_leased")
  acceptTerms          Boolean     @default(false)               @map("accept_terms")
  userId               String      @unique
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carrier_profiles")
}

model LeaseDetails {
  id                String      @id @default(uuid())
  lessorName        DateTime    @default(now())            @map("lessor_name")
  contractNumber    DateTime    @map("contract_number")
  expiryDate        String      @map("expiry_date")
  leaseAgreement    String      @map("lease_agreement")
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lease_details")
}

model RefreshToken {
  id           String      @id @default(uuid())
  createdAt    DateTime    @default(now())          @map("created_at")
  expiresAt    DateTime    @map("expires_at")
  token        String
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model UserSocial {
  id             String    @id @default(uuid())
  accessToken    String?   @map("access_token")
  createdAt      DateTime  @default(now())            @map("created_at")
  email          String?
  isLinked       Int?      @map("is_linked")
  provider       String?
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  updatedAt      DateTime  @updatedAt
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_socials")
}

model AuditLog {
  id           String      @id @default(uuid())
  action       String
  createdAt    DateTime    @default(now())        @map("created_at")
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model ResetPassword {
  id           String      @id @default(uuid())
  createdAt    DateTime    @default(now())          @map("created_at")
  expiresAt    DateTime    @map("expires_at")
  tokenHash    String      @map("token_hash")
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reset_passwords")
}

model Product {
  id             String         @id @default(uuid())
  name           String
  description    String?
  price          Decimal
  stock          Int
  sku            String         @unique
  isActive       Boolean        @default(true)          @map("is_active")
  imageUrl       String?        @map("image_url")
  cartItems      CartItem[]
  orderItems     OrderItem[]
  categoryId     String         
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())         @map("created_at")
  updatedAt      DateTime       @updatedAt              @map("updated_at")

  @@map("products")
}

model Category {
  id             String       @id @default(uuid())
  name           String
  description    String?
  status         String?
  slug           String       @unique
  imageUrl       String?      @map("image_url")
  createdAt      DateTime     @default(now())         @map("created_at")
  updatedAt      DateTime     @updatedAt              @map("updated_at")
  products       Product[]

  @@map("categories")
}

model Order {
  id                 String         @id @default(uuid())
  orderNumber        String         @unique                     @map("order_number")
  status             String?
  totalAmount        Decimal        @map("total_amount")
  shippingAddress    String?        @map("shipping_address")
  createdAt          DateTime       @default(now())             @map("created_at")
  updatedAt          DateTime       @updatedAt                  @map("updated_at")
  orderItems         OrderItem[]
  payments           Payment[]
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartId             String
  cart               Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model Cart {
  id            String        @id @default(uuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkedOut    Boolean       @default(false)        @map("checked_out")
  createdAt     DateTime      @default(now())        @map("created_at")
  updatedAt     DateTime      @updatedAt             @map("updated_at")
  cartItems     CartItem[]
  orders        Order[]

  @@map("carts")
}

model CartItem {
  id           String      @id @default(uuid())
  quantity     Int
  cartId       String
  cart         Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId    String
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())         @map("created_at")
  updatedAt    DateTime    @updatedAt              @map("updated_at")

  @@map("cart_items")
}

model OrderItem {
  id           String      @id @default(uuid())
  quantity     Int
  price        Decimal
  orderId      String
  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())         @map("created_at")
  updatedAt    DateTime    @updatedAt              @map("updated_at")

  @@map("order_items")
}

model Payment {
  id               String      @id @default(uuid())
  amount           Decimal
  status           String?
  currency         String      @default("UAH")
  paymentMethod    String?     @map("payment_method")
  transactionId    String?
  orderId          String
  order            Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())          @map("created_at")
  updatedAt        DateTime    @updatedAt               @map("updated_at")
  transactions  Transaction[]

  @@map("payments")
}

model Token {
  id            String       @id @default(uuid())
  token         String       @unique
  expiresAt     DateTime     @map("expires_at")
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

model Transaction {
  id            String   @id @default(uuid())
  type          String   
  amount        Decimal  
  currency      String   @default("UAH")
  status        String   
  description   String? 
  referenceId   String?  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId     String?  
  payment       Payment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("transactions")
}